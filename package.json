{
  "name": "mermaid-png-mcp",
  "version": "1.0.0",
  "description": "Mermaid → PNG MCP server. Zero-DOM (beautiful-mermaid) + CDN mermaid (subgraphs). Renders diagrams to PNG via the render_mermaid tool.",
  "main": "mermaid/src/mcp-server.mjs",
  "bin": {
    "mermaid-png-mcp": "mermaid/src/mcp-server.mjs"
  },
  "files": [
    "mermaid/src/mcp-server.mjs",
    "mermaid/src/render-beautiful.mjs",
    "mermaid/src/render-cdn.cjs",
    "drawio-bridge/src/svg2png.js",
    "markdown-card/src/render.js",
    "mermaid/examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node mermaid/src/mcp-server.mjs"
  },
  "keywords": ["mermaid", "mcp", "png", "diagram", "mcp-server", "modelcontextprotocol"],
  "license": "MIT",
  "repository": "github:alitrack/diagram-pipelines",
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "playwright": "^1.61.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
